# Portfolio contact form (Gmail SMTP + App Password)
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# Where submissions are delivered (usually your inbox)
CONTACT_TO_EMAIL=dareyes@my.cspc.edu.ph

# Sender shown in the email (defaults to SMTP_USER)
CONTACT_FROM_EMAIL=your@gmail.com
